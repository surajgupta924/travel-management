{
  "name": "travel-management",
  "version": "1.0.0",
  "description": "Full-stack Travel & Tourism Management System built with the MERN stack",
  "author": "Suraj Gupta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/surajgupta924/travel-management.git"
  },
  "keywords": [
    "mern",
    "travel",
    "tourism",
    "booking",
    "react",
    "express",
    "mongodb",
    "portfolio"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "install-all": "npm install --prefix backend && npm install --prefix frontend",
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "server": "npm run dev --prefix backend",
    "client": "npm run dev --prefix frontend",
    "start": "npm run start --prefix backend",
    "seed": "npm run seed --prefix backend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
