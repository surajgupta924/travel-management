# Server
PORT=5000
NODE_ENV=development

# Database — use local MongoDB or MongoDB Atlas connection string
# Local:  mongodb://localhost:27017/travel_tourism
# Atlas:  mongodb+srv://<username>:<password>@<cluster>.mongodb.net/travel_tourism?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/travel_tourism

# Authentication — generate a strong random string for production
# Example: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# CORS — comma-separated allowed origins (frontend URL in production)
CLIENT_URL=http://localhost:3000
